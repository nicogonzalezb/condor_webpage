---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import { CASOS_IA_DIRECTORY_BASE, DIRECTORIOS_HUB_PATH } from '@/lib/directorioUrls'
---

<BaseLayout
  title="Directorios Condór"
  description="Índice de directorios editoriales: casos de uso de IA y más recursos por venir."
>
  <div class="container-condor py-14 md:py-20">
    <SectionHeading
      title="Directorios"
      subtitle="Explora directorios curados por industria, área y tipo de contenido. Cada uno tiene su propia URL y taxonomía."
    />

    <ul class="mt-10 grid gap-6 md:grid-cols-2">
      <li class="rounded-2xl border border-condor-navy/10 bg-background-card p-8 shadow-[var(--shadow-card)]">
        <h2 class="text-lg font-bold text-condor-navy">Casos de uso IA</h2>
        <p class="mt-2 text-sm leading-6 text-foreground-muted">
          Casos con datos requeridos, riesgos, KPIs, fuentes y hubs por industria, área y tipo de IA.
        </p>
        <div class="mt-6">
          <Button href={CASOS_IA_DIRECTORY_BASE} variant="accent">
            Abrir directorio
          </Button>
        </div>
      </li>
      <li class="rounded-2xl border border-dashed border-condor-navy/20 bg-condor-navy/5 p-8">
        <h2 class="text-lg font-bold text-foreground-muted">Próximos directorios</h2>
        <p class="mt-2 text-sm leading-6 text-foreground-muted">
          Aquí enlazaremos nuevos directorios (por ejemplo proveedores, frameworks o verticales) sin mezclar taxonomías.
        </p>
      </li>
    </ul>

    <p class="mt-10 text-xs text-foreground-muted" style="font-family: var(--font-condor-mono);">
      Más directorios se publicarán en <code class="text-condor-bluegray">{DIRECTORIOS_HUB_PATH}</code>
    </p>
  </div>
</BaseLayout>
