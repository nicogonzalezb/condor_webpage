---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import { sanity } from '@/lib/sanity'

const fichas = sanity
  ? await sanity.fetch<{
  slug: string
  title: string
  industria: string
  areaFuncional: string
  descripcion: string
  complejidad: string
  kpis: string[]
  tipoIA: string | null
  faseAdopcion: string | null
  nivelEvidencia: string | null
}[]>(`
  *[_type == "useCaseFicha" && (!defined(estadoPublicacion) || estadoPublicacion == "publicado")] | order(industria asc, title asc) {
    "slug": slug.current,
    title,
    industria,
    areaFuncional,
    descripcion,
    complejidad,
    kpis,
    tipoIA,
    faseAdopcion,
    nivelEvidencia
  }
`)
  : []

const tipoIALabels: Record<string, string> = {
  predictivo: 'Predictivo',
  generativo: 'Generativo',
  recomendacion: 'Recomendación',
  clasificacion: 'Clasificación',
  vision: 'Visión',
  nlp: 'NLP',
  agentes: 'Agentes',
  optimizacion: 'Optimización',
}

const faseAdopcionLabels: Record<string, string> = {
  exploracion: 'Exploración',
  piloto: 'Piloto',
  escala: 'Escala',
  optimizacion: 'Optimización',
}

const nivelEvidenciaShort: Record<string, string> = {
  observacional: 'Marcos / guías',
  piloto_benchmark: 'Piloto / benchmark',
  produccion_documentada: 'Producción',
}

const industrias = [...new Set(fichas.map((f) => f.industria))].sort()
const areas = [...new Set(fichas.map((f) => f.areaFuncional))].sort()
const complejidadOrden = ['baja', 'media', 'alta'] as const
const complejidadesPresentes = complejidadOrden.filter((c) =>
  fichas.some((f) => f.complejidad === c),
)

const tiposPresentes = [
  ...new Set(
    fichas.map((f) => f.tipoIA).filter((v): v is string => typeof v === 'string' && v.length > 0),
  ),
].sort((a, b) =>
  (tipoIALabels[a] ?? a).localeCompare(tipoIALabels[b] ?? b, 'es'),
)

const fasesPresentes = [
  ...new Set(
    fichas
      .map((f) => f.faseAdopcion)
      .filter((v): v is string => typeof v === 'string' && v.length > 0),
  ),
].sort((a, b) =>
  (faseAdopcionLabels[a] ?? a).localeCompare(faseAdopcionLabels[b] ?? b, 'es'),
)

const chipBase =
  'directorio-filter-chip rounded-full border px-3 py-1.5 text-xs font-semibold transition-colors border-condor-navy/20 bg-background-card text-foreground-muted hover:border-condor-navy/35 aria-pressed:border-condor-sky/50 aria-pressed:bg-condor-sky/20 aria-pressed:text-condor-bluegray aria-pressed:ring-1 aria-pressed:ring-condor-sky/30'
---

<BaseLayout
  title="Directorio de casos de uso IA"
  description="Fichas verificables de casos de uso AI-first por industria: datos requeridos, riesgos, KPIs y evidencia citada."
>
  <div class="container-condor py-14 md:py-20">
    <SectionHeading
      title="Directorio de casos de uso IA"
      subtitle="Fichas verificadas por industria, área, complejidad, tipo de IA y fase de adopción."
    />

    {fichas.length === 0 ? (
      <div class="rounded-2xl border border-condor-navy/10 bg-background-card p-10 text-center shadow-[var(--shadow-card)]">
        <p class="text-sm text-foreground-muted">Las fichas están en construcción. Vuelve pronto.</p>
      </div>
    ) : (
      <>
        <div
          id="directorio-filtros"
          class="mb-10 space-y-6 rounded-2xl border border-condor-navy/10 bg-background-card p-6 shadow-[var(--shadow-card)]"
        >
          <div class="flex flex-wrap items-end justify-between gap-4">
            <p class="text-sm text-foreground-muted max-w-xl">
              Filtra por industria, área, complejidad, tipo de IA y fase de adopción. La URL guarda la selección (<code class="text-condor-bluegray">tipo</code>, <code class="text-condor-bluegray">fase</code>, etc.).
            </p>
            <button
              type="button"
              id="directorio-filtros-limpiar"
              class="hidden text-xs font-semibold text-condor-bluegray underline underline-offset-2 hover:text-foreground"
            >
              Limpiar filtros
            </button>
          </div>

          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <fieldset class="min-w-0">
              <legend class="mb-2 text-xs font-bold uppercase tracking-wide text-foreground-muted" style="font-family: var(--font-condor-mono);">
                Industria
              </legend>
              <div class="flex flex-wrap gap-2" data-filter-group="industria">
                <button
                  type="button"
                  class={chipBase}
                  data-dimension="industria"
                  data-value=""
                  aria-pressed="true"
                >
                  Todas
                </button>
                {industrias.map((ind) => (
                  <button
                    type="button"
                    class={chipBase}
                    style="font-family: var(--font-condor-mono);"
                    data-dimension="industria"
                    data-value={ind}
                    aria-pressed="false"
                  >
                    {ind}
                  </button>
                ))}
              </div>
            </fieldset>

            <fieldset class="min-w-0">
              <legend class="mb-2 text-xs font-bold uppercase tracking-wide text-foreground-muted" style="font-family: var(--font-condor-mono);">
                Área funcional
              </legend>
              <div class="flex flex-wrap gap-2" data-filter-group="area">
                <button
                  type="button"
                  class={chipBase}
                  data-dimension="area"
                  data-value=""
                  aria-pressed="true"
                >
                  Todas
                </button>
                {areas.map((ar) => (
                  <button
                    type="button"
                    class={chipBase}
                    style="font-family: var(--font-condor-mono);"
                    data-dimension="area"
                    data-value={ar}
                    aria-pressed="false"
                  >
                    {ar}
                  </button>
                ))}
              </div>
            </fieldset>

            <fieldset class="min-w-0 sm:col-span-2 lg:col-span-1">
              <legend class="mb-2 text-xs font-bold uppercase tracking-wide text-foreground-muted" style="font-family: var(--font-condor-mono);">
                Complejidad
              </legend>
              <div class="flex flex-wrap gap-2" data-filter-group="complejidad">
                <button
                  type="button"
                  class={chipBase}
                  data-dimension="complejidad"
                  data-value=""
                  aria-pressed="true"
                >
                  Todas
                </button>
                {complejidadesPresentes.map((c) => (
                  <button
                    type="button"
                    class={`${chipBase} capitalize`}
                    data-dimension="complejidad"
                    data-value={c}
                    aria-pressed="false"
                  >
                    {c}
                  </button>
                ))}
              </div>
            </fieldset>
          </div>

          {(tiposPresentes.length > 0 || fasesPresentes.length > 0) && (
            <div class="grid gap-6 border-t border-condor-navy/10 pt-6 sm:grid-cols-2">
              {tiposPresentes.length > 0 && (
                <fieldset class="min-w-0">
                  <legend class="mb-2 text-xs font-bold uppercase tracking-wide text-foreground-muted" style="font-family: var(--font-condor-mono);">
                    Tipo de IA
                  </legend>
                  <div class="flex flex-wrap gap-2" data-filter-group="tipo">
                    <button
                      type="button"
                      class={chipBase}
                      data-dimension="tipo"
                      data-value=""
                      aria-pressed="true"
                    >
                      Todos
                    </button>
                    {tiposPresentes.map((t) => (
                      <button
                        type="button"
                        class={chipBase}
                        style="font-family: var(--font-condor-mono);"
                        data-dimension="tipo"
                        data-value={t}
                        aria-pressed="false"
                      >
                        {tipoIALabels[t] ?? t}
                      </button>
                    ))}
                  </div>
                </fieldset>
              )}

              {fasesPresentes.length > 0 && (
                <fieldset class="min-w-0">
                  <legend class="mb-2 text-xs font-bold uppercase tracking-wide text-foreground-muted" style="font-family: var(--font-condor-mono);">
                    Fase de adopción
                  </legend>
                  <div class="flex flex-wrap gap-2" data-filter-group="fase">
                    <button
                      type="button"
                      class={chipBase}
                      data-dimension="fase"
                      data-value=""
                      aria-pressed="true"
                    >
                      Todas
                    </button>
                    {fasesPresentes.map((fa) => (
                      <button
                        type="button"
                        class={chipBase}
                        style="font-family: var(--font-condor-mono);"
                        data-dimension="fase"
                        data-value={fa}
                        aria-pressed="false"
                      >
                        {faseAdopcionLabels[fa] ?? fa}
                      </button>
                    ))}
                  </div>
                </fieldset>
              )}
            </div>
          )}

        </div>

        <p
          id="directorio-filter-empty"
          class="mb-8 hidden rounded-2xl border border-condor-navy/10 bg-background-card px-6 py-8 text-center text-sm text-foreground-muted shadow-[var(--shadow-card)]"
          role="status"
        >
          Ninguna ficha coincide con los filtros seleccionados.
        </p>

        <!-- Grid de fichas -->
        <div id="directorio-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {fichas.map((f) => (
            <div
              class="group flex flex-col rounded-2xl border border-condor-navy/10 bg-background-card p-7 shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:border-condor-navy/25 transition-all duration-200"
              data-directorio-card
              data-industria={f.industria}
              data-area={f.areaFuncional}
              data-complejidad={f.complejidad ?? ''}
              data-tipo={f.tipoIA ?? ''}
              data-fase={f.faseAdopcion ?? ''}
            >
              <!-- Header -->
              <div class="flex items-start justify-between gap-3">
                <div class="text-base font-bold text-foreground group-hover:text-condor-bluegray transition-colors duration-200 leading-snug">
                  {f.title}
                </div>
                {f.complejidad && (
                  <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${
                    f.complejidad === 'baja'
                      ? 'bg-condor-sky/20 text-condor-bluegray'
                      : f.complejidad === 'media'
                      ? 'bg-condor-pink/30 text-foreground'
                      : 'bg-condor-navy/10 text-foreground'
                  }`}>
                    {f.complejidad}
                  </span>
                )}
              </div>

              <!-- Tags -->
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span
                  class="rounded-full bg-condor-sky/20 border border-condor-sky/40 px-2.5 py-0.5 text-xs text-condor-bluegray"
                  style="font-family: var(--font-condor-mono);"
                >
                  {f.industria}
                </span>
                <span
                  class="rounded-full bg-condor-navy/8 border border-condor-navy/15 px-2.5 py-0.5 text-xs text-foreground-muted"
                  style="font-family: var(--font-condor-mono);"
                >
                  {f.areaFuncional}
                </span>
              </div>

              {(f.tipoIA || f.faseAdopcion || f.nivelEvidencia) && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {f.tipoIA && (
                    <span
                      class="rounded-full border border-condor-navy/12 bg-condor-navy/5 px-2.5 py-0.5 text-[11px] font-medium text-foreground-muted"
                      style="font-family: var(--font-condor-mono);"
                      title="Tipo de IA"
                    >
                      {tipoIALabels[f.tipoIA] ?? f.tipoIA}
                    </span>
                  )}
                  {f.faseAdopcion && (
                    <span
                      class="rounded-full border border-dashed border-condor-navy/25 bg-transparent px-2.5 py-0.5 text-[11px] text-foreground-muted"
                      style="font-family: var(--font-condor-mono);"
                      title="Fase de adopción"
                    >
                      {faseAdopcionLabels[f.faseAdopcion] ?? f.faseAdopcion}
                    </span>
                  )}
                  {f.nivelEvidencia && (
                    <span
                      class="rounded-full border border-dotted border-condor-navy/20 px-2 py-0.5 text-[11px] text-foreground-muted/90"
                      style="font-family: var(--font-condor-mono);"
                      title="Nivel de evidencia"
                    >
                      {nivelEvidenciaShort[f.nivelEvidencia] ?? f.nivelEvidencia}
                    </span>
                  )}
                </div>
              )}

              <!-- Descripción -->
              <p class="mt-4 text-sm leading-6 text-foreground-muted line-clamp-3 flex-1">
                {f.descripcion}
              </p>

              <!-- KPIs preview -->
              {f.kpis?.length > 0 && (
                <div class="mt-4 text-xs text-foreground-muted">
                  <span class="font-semibold">KPIs:</span>{' '}
                  {f.kpis.slice(0, 2).join(' · ')}
                  {f.kpis.length > 2 && ` +${f.kpis.length - 2}`}
                </div>
              )}

              <div class="mt-6">
                <Button href={`/directorio/${f.slug}`} variant="secondary">
                  Ver ficha completa
                </Button>
              </div>
            </div>
          ))}
        </div>

        <script is:inline>
          (function () {
            const cards = () =>
              Array.from(document.querySelectorAll('[data-directorio-card]'))
            const emptyEl = document.getElementById('directorio-filter-empty')
            const clearBtn = document.getElementById('directorio-filtros-limpiar')
            const chips = () =>
              Array.from(
                document.querySelectorAll('.directorio-filter-chip'),
              )

            const state = {
              industria: '',
              area: '',
              complejidad: '',
              tipo: '',
              fase: '',
            }

            function readUrl() {
              const p = new URLSearchParams(window.location.search)
              state.industria = p.get('industria') ?? ''
              state.area = p.get('area') ?? ''
              state.complejidad = p.get('complejidad') ?? ''
              state.tipo = p.get('tipo') ?? ''
              state.fase = p.get('fase') ?? ''
            }

            function writeUrl() {
              const p = new URLSearchParams()
              if (state.industria) p.set('industria', state.industria)
              if (state.area) p.set('area', state.area)
              if (state.complejidad) p.set('complejidad', state.complejidad)
              if (state.tipo) p.set('tipo', state.tipo)
              if (state.fase) p.set('fase', state.fase)
              const q = p.toString()
              const next = q
                ? `${window.location.pathname}?${q}`
                : window.location.pathname
              window.history.replaceState(null, '', next)
            }

            function clampStateToDom() {
              const inds = new Set(
                cards().map((c) => c.getAttribute('data-industria') || ''),
              )
              const ars = new Set(
                cards().map((c) => c.getAttribute('data-area') || ''),
              )
              const comps = new Set(
                cards().map((c) => c.getAttribute('data-complejidad') || ''),
              )
              const tipos = new Set(
                cards().map((c) => c.getAttribute('data-tipo') || ''),
              )
              const fases = new Set(
                cards().map((c) => c.getAttribute('data-fase') || ''),
              )
              if (state.industria && !inds.has(state.industria)) {
                state.industria = ''
              }
              if (state.area && !ars.has(state.area)) state.area = ''
              if (state.complejidad && !comps.has(state.complejidad)) {
                state.complejidad = ''
              }
              if (state.tipo && !tipos.has(state.tipo)) state.tipo = ''
              if (state.fase && !fases.has(state.fase)) state.fase = ''
            }

            function syncChips() {
              const curByDim = {
                industria: state.industria,
                area: state.area,
                complejidad: state.complejidad,
                tipo: state.tipo,
                fase: state.fase,
              }
              for (const btn of chips()) {
                const dim = btn.getAttribute('data-dimension')
                const val = btn.getAttribute('data-value') ?? ''
                if (!dim || !(dim in curByDim)) continue
                const cur = curByDim[dim]
                btn.setAttribute('aria-pressed', val === cur ? 'true' : 'false')
              }
              const any =
                !!state.industria ||
                !!state.area ||
                !!state.complejidad ||
                !!state.tipo ||
                !!state.fase
              clearBtn?.classList.toggle('hidden', !any)
            }

            function apply() {
              let n = 0
              for (const card of cards()) {
                const dInd = card.getAttribute('data-industria') || ''
                const dArea = card.getAttribute('data-area') || ''
                const dComp = card.getAttribute('data-complejidad') || ''
                const dTipo = card.getAttribute('data-tipo') || ''
                const dFase = card.getAttribute('data-fase') || ''
                const ok =
                  (!state.industria || dInd === state.industria) &&
                  (!state.area || dArea === state.area) &&
                  (!state.complejidad || dComp === state.complejidad) &&
                  (!state.tipo || dTipo === state.tipo) &&
                  (!state.fase || dFase === state.fase)
                card.classList.toggle('hidden', !ok)
                if (ok) n++
              }
              emptyEl?.classList.toggle('hidden', n !== 0)
            }

            function setDim(dim, value) {
              if (dim === 'industria') state.industria = value
              if (dim === 'area') state.area = value
              if (dim === 'complejidad') state.complejidad = value
              if (dim === 'tipo') state.tipo = value
              if (dim === 'fase') state.fase = value
              writeUrl()
              syncChips()
              apply()
            }

            function init() {
              readUrl()
              clampStateToDom()
              writeUrl()
              syncChips()
              apply()

              for (const btn of chips()) {
                btn.addEventListener('click', () => {
                  const dim = btn.getAttribute('data-dimension')
                  const val = btn.getAttribute('data-value') ?? ''
                  if (!dim) return
                  setDim(dim, val)
                })
              }

              clearBtn?.addEventListener('click', () => {
                state.industria = ''
                state.area = ''
                state.complejidad = ''
                state.tipo = ''
                state.fase = ''
                writeUrl()
                syncChips()
                apply()
              })
            }

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', init)
            } else {
              init()
            }
          })()
        </script>
      </>
    )}
  </div>
</BaseLayout>
