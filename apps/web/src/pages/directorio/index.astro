---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import { sanity } from '@/lib/sanity'

const fichas = await sanity.fetch<{
  slug: string
  title: string
  industria: string
  areaFuncional: string
  descripcion: string
  complejidad: string
  kpis: string[]
}[]>(`
  *[_type == "useCaseFicha"] | order(industria asc, title asc) {
    "slug": slug.current,
    title,
    industria,
    areaFuncional,
    descripcion,
    complejidad,
    kpis
  }
`)

const industrias = [...new Set(fichas.map((f) => f.industria))].sort()
---

<BaseLayout
  title="Directorio de casos de uso IA"
  description="Fichas verificables de casos de uso AI-first por industria: datos requeridos, riesgos, KPIs y evidencia citada."
>
  <div class="container-condor py-14 md:py-20">
    <SectionHeading
      title="Directorio de casos de uso IA"
      subtitle="Fichas verificadas por industria, área funcional y nivel de complejidad."
    />

    {fichas.length === 0 ? (
      <div class="rounded-2xl border border-condor-navy/10 bg-background-card p-10 text-center shadow-[var(--shadow-card)]">
        <p class="text-sm text-foreground-muted">Las fichas están en construcción. Vuelve pronto.</p>
      </div>
    ) : (
      <>
        <!-- Filtros por industria -->
        <div class="mb-8 flex flex-wrap gap-2">
          {industrias.map((ind) => (
            <span
              class="rounded-full border border-condor-navy/20 bg-background-card px-4 py-1.5 text-xs font-semibold text-foreground-muted"
              style="font-family: var(--font-condor-mono);"
            >
              {ind}
            </span>
          ))}
        </div>

        <!-- Grid de fichas -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {fichas.map((f) => (
            <div class="group flex flex-col rounded-2xl border border-condor-navy/10 bg-background-card p-7 shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:border-condor-navy/25 transition-all duration-200">
              <!-- Header -->
              <div class="flex items-start justify-between gap-3">
                <div class="text-base font-bold text-foreground group-hover:text-condor-bluegray transition-colors duration-200 leading-snug">
                  {f.title}
                </div>
                {f.complejidad && (
                  <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${
                    f.complejidad === 'baja'
                      ? 'bg-condor-sky/20 text-condor-bluegray'
                      : f.complejidad === 'media'
                      ? 'bg-condor-pink/30 text-foreground'
                      : 'bg-condor-navy/10 text-foreground'
                  }`}>
                    {f.complejidad}
                  </span>
                )}
              </div>

              <!-- Tags -->
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span
                  class="rounded-full bg-condor-sky/20 border border-condor-sky/40 px-2.5 py-0.5 text-xs text-condor-bluegray"
                  style="font-family: var(--font-condor-mono);"
                >
                  {f.industria}
                </span>
                <span
                  class="rounded-full bg-condor-navy/8 border border-condor-navy/15 px-2.5 py-0.5 text-xs text-foreground-muted"
                  style="font-family: var(--font-condor-mono);"
                >
                  {f.areaFuncional}
                </span>
              </div>

              <!-- Descripción -->
              <p class="mt-4 text-sm leading-6 text-foreground-muted line-clamp-3 flex-1">
                {f.descripcion}
              </p>

              <!-- KPIs preview -->
              {f.kpis?.length > 0 && (
                <div class="mt-4 text-xs text-foreground-muted">
                  <span class="font-semibold">KPIs:</span>{' '}
                  {f.kpis.slice(0, 2).join(' · ')}
                  {f.kpis.length > 2 && ` +${f.kpis.length - 2}`}
                </div>
              )}

              <div class="mt-6">
                <Button href={`/directorio/${f.slug}`} variant="secondary">
                  Ver ficha completa
                </Button>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>
